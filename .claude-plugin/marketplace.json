{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "quality-engineering-skills",
  "description": "Curated marketplace of quality-engineering, test-automation, and SDLC plugins for Claude Code \u2014 ELITEA Next MCP, QA agents, test-framework skill bundles (qavajs, Vividus, Tosca, ServiceNow ATF), agent-evaluator, and the full sdlc-skills role-based agent toolkit drilled down into 30 installable plugins.",
  "owner": {
    "name": "Alexander Bychinskiy",
    "url": "https://github.com/bermudas"
  },
  "plugins": [
    {
      "name": "elitea-next",
      "source": "./external_plugins/elitea-next",
      "description": "Connect Claude Code to an EPAM ELITEA Next project over SSE. Reads project id from a server-scoped env block and bearer token from a local .env file via headersHelper.",
      "author": {
        "name": "Alexander Bychinskiy",
        "url": "https://github.com/bermudas"
      },
      "category": "mcp",
      "homepage": "https://elitea.ai"
    },
    {
      "name": "qa-agent",
      "source": "./external_plugins/qa-agent",
      "description": "Composable QA agent for AI coding assistants \u2014 multi-specialist analysis, exploratory testing, accessibility, security, test generation, with a /qa-init onboarding pipeline. Wrapper around onetest-ai/qa-agent's npx installer.",
      "author": {
        "name": "onetest-ai",
        "url": "https://github.com/onetest-ai"
      },
      "category": "testing",
      "homepage": "https://github.com/onetest-ai/qa-agent"
    },
    {
      "name": "agent-evaluator",
      "source": "./external_plugins/agent-evaluator",
      "description": "Evaluate AI agent specifications against the Agent Maturity Model (L0\u2013L3, 39 practices across 9 categories) and produce a styled HTML maturity assessment report. Triggers on 'evaluate this agent', 'score these agents', 'how mature is X', 'audit the agent suite in folder Y'. Vendored from dshaplyko/skills.",
      "author": {
        "name": "Dmitry Shaplyko",
        "url": "https://github.com/dshaplyko"
      },
      "category": "agent-quality",
      "homepage": "https://github.com/dshaplyko/skills/tree/main/.claude/skills/agent-evaluator"
    },
    {
      "name": "qaspace-skill",
      "source": "./external_plugins/qaspace-skill",
      "description": "Agent skill for the EPAM qaspace Test Management Plugin on Jira Server/DC. Discover custom-field IDs, resolve test runs, build folder trees, triage runs for automation, paginate large runs, avoid plugin footguns. Transport-agnostic \u2014 MCP, REST, or curl.",
      "author": {
        "name": "Alexander Bychinskiy",
        "url": "https://github.com/bermudas"
      },
      "category": "test-management",
      "homepage": "https://github.com/bermudas/qaspace-skill"
    },
    {
      "name": "qavajs-skill",
      "source": "./external_plugins/qavajs-skill",
      "description": "Agent skill for the qavajs BDD test-automation framework \u2014 270 step patterns, full configuration and DSL reference, Playwright MCP bundled. Use when bootstrapping a qavajs project, authoring step definitions, or debugging test runs.",
      "author": {
        "name": "Alexander Bychinskiy",
        "url": "https://github.com/bermudas"
      },
      "category": "testing",
      "homepage": "https://github.com/bermudas/qavajs-skill"
    },
    {
      "name": "vividus-skill",
      "source": "./external_plugins/vividus-skill",
      "description": "Agent skill for the Vividus test-automation framework \u2014 bootstrap a project, configure profiles and environments, author scenarios, run suites. Bundles a Playwright MCP for browser-driven steps.",
      "author": {
        "name": "Alexander Bychinskiy",
        "url": "https://github.com/bermudas"
      },
      "category": "testing",
      "homepage": "https://github.com/bermudas/vividus-skill"
    },
    {
      "name": "tosca-tsu",
      "source": "./external_plugins/tosca-tsu",
      "description": "Bidirectional bridge between Tricentis Tosca .tsu test bundles and Playwright TypeScript specs. Generate .tsu from Playwright, parse .tsu into Playwright, drive the browser via Playwright MCP. Ships Claude Code skills plus Playwright MCP configs for VS Code, Copilot, and Copilot CLI.",
      "author": {
        "name": "Alexander Bychinskiy",
        "url": "https://github.com/bermudas"
      },
      "category": "testing",
      "homepage": "https://github.com/bermudas/ToscaTSU"
